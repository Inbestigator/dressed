{
  "name": "@dressed/react",
  "version": "2.0.0",
  "description": "Render Dressed's components using React.",
  "keywords": [
    "dressed",
    "react",
    "jsx",
    "discord"
  ],
  "homepage": "https://dressed.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inbestigator/dressed.git",
    "directory": "packages/dressed-react"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
