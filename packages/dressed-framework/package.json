{
  "name": "@dressed/framework",
  "version": "0.5.0",
  "description": "A framework for creating Discord bots using Dressed.",
  "keywords": [
    "framework",
    "serverless",
    "dressed",
    "discord"
  ],
  "homepage": "https://dressed.js.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inbestigator/dressed.git",
    "directory": "packages/dressed-framework"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./build": "./dist/build/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "dressed": "dist/bin/dressed.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "dist": "rm -fr dist && tsc",
    "dry-publish": "bun publish --dry-run",
    "test": "bun test"
  },
  "dependencies": {
    "@dressed/matcher": "^1.4.0",
    "commander": "^15.0.0",
    "esbuild": "^0.28.1",
    "fast-glob": "^3.3.3"
  },
  "peerDependencies": {
    "dressed": "^2.0.0-canary.1"
  }
}
